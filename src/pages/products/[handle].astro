---
import Base from "@/layouts/Base.astro";
import TargetArt from "@/components/TargetArt.astro";
import StarRating from "@/components/StarRating.astro";
import ProductCard from "@/components/ProductCard.astro";
import { getProducts } from "@/lib/catalog";
import { CATEGORY_LABELS } from "@/lib/types";
import { formatMoney } from "@/lib/format";

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((product) => ({
    params: { handle: product.handle },
    props: { product, all: products },
  }));
}

const { product, all } = Astro.props;
const multi = product.variants.length > 1;

const related = all
  .filter((p) => p.category === product.category && p.handle !== product.handle)
  .slice(0, 4);

const addPayload = JSON.stringify({
  variantId: product.variants[0].id,
  handle: product.handle,
  title: product.title,
  variantTitle: product.variants[0].title,
  price: product.variants[0].price,
  art: product.art,
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.title,
  description: product.description,
  category: CATEGORY_LABELS[product.category],
  brand: { "@type": "Brand", name: "Splatter Impacts" },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: product.priceFrom.currencyCode,
    lowPrice: product.priceFrom.amount,
    offerCount: product.variants.length,
    availability: product.variants.some((v) => v.available)
      ? "https://schema.org/InStock"
      : "https://schema.org/OutOfStock",
  },
  ...(product.rating
    ? {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: product.rating.value,
          reviewCount: product.rating.count,
        },
      }
    : {}),
};
---
<Base title={product.title} description={product.subtitle ?? product.description.slice(0, 150)}>
  <div class="container-page py-6">
    <nav class="text-sm text-steel-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blaze-400">Home</a>
      <span class="mx-2">/</span>
      <a href={`/shop?c=${product.category}`} class="hover:text-blaze-400">{CATEGORY_LABELS[product.category]}</a>
      <span class="mx-2">/</span>
      <span class="text-steel-300">{product.title}</span>
    </nav>
  </div>

  <section class="container-page grid gap-10 pb-16 lg:grid-cols-2">
    <div class="card overflow-hidden">
      <div class="aspect-square bg-steel-950"><TargetArt art={product.art} /></div>
    </div>

    <div>
      <div class="flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-steel-800 px-2.5 py-1 text-xs font-medium text-steel-300">{CATEGORY_LABELS[product.category]}</span>
        {product.bestseller && <span class="rounded-full bg-blaze-500 px-2.5 py-1 text-xs font-bold uppercase text-white">Bestseller</span>}
      </div>

      <h1 class="mt-3 font-display text-4xl font-bold text-steel-50">{product.title}</h1>
      {product.subtitle && <p class="mt-1 text-lg text-steel-400">{product.subtitle}</p>}
      {product.rating && <StarRating value={product.rating.value} count={product.rating.count} class="mt-3" />}

      <p class="mt-5 font-display text-3xl font-semibold text-blaze-400" data-price>
        {formatMoney(product.variants[0].price)}
      </p>

      <p class="mt-5 leading-relaxed text-steel-300">{product.description}</p>

      {multi && (
        <div class="mt-6">
          <label for="variant" class="mb-2 block text-sm font-medium text-steel-300">Option</label>
          <select
            id="variant"
            class="w-full rounded-lg border border-steel-600 bg-steel-950 px-4 py-3 text-steel-100 focus:border-blaze-500 focus:outline-none"
          >
            {product.variants.map((v) => (
              <option
                value={v.id}
                data-title={v.title}
                data-amount={v.price.amount}
                data-currency={v.price.currencyCode}
                disabled={!v.available}
              >
                {v.title} — {formatMoney(v.price)}{!v.available ? " (sold out)" : ""}
              </option>
            ))}
          </select>
        </div>
      )}

      <div class="mt-6 flex gap-3">
        <button
          type="button"
          class="btn btn-primary flex-1 text-base"
          data-add={addPayload}
          data-variant-select={multi ? "#variant" : undefined}
        >
          Add to cart
        </button>
        <button type="button" class="btn btn-ghost text-base" data-cart-open>View cart</button>
      </div>

      <ul class="mt-8 grid gap-2.5">
        {product.bullets.map((b) => (
          <li class="flex gap-3 text-steel-300">
            <svg viewBox="0 0 20 20" class="mt-0.5 h-5 w-5 shrink-0 text-splat-500" fill="currentColor" aria-hidden="true">
              <path d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0z"/>
            </svg>
            <span class="text-sm">{b}</span>
          </li>
        ))}
      </ul>

      {product.specs.length > 0 && (
        <dl class="mt-8 divide-y divide-steel-800 border-t border-steel-800">
          {product.specs.map((s) => (
            <div class="flex justify-between gap-4 py-3 text-sm">
              <dt class="text-steel-500">{s.label}</dt>
              <dd class="text-right font-medium text-steel-200">{s.value}</dd>
            </div>
          ))}
        </dl>
      )}
    </div>
  </section>

  {related.length > 0 && (
    <section class="border-t border-steel-800 bg-steel-900/30">
      <div class="container-page py-14">
        <h2 class="font-display text-2xl font-bold text-steel-50">You might also like</h2>
        <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {related.map((p) => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}

  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <script>
    // keep the displayed price in sync with the selected variant
    const select = document.querySelector<HTMLSelectElement>("#variant");
    const price = document.querySelector<HTMLElement>("[data-price]");
    select?.addEventListener("change", () => {
      const opt = select.selectedOptions[0];
      if (opt && price) {
        const amt = Number(opt.dataset.amount);
        price.textContent = new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: opt.dataset.currency || "USD",
          minimumFractionDigits: Number.isInteger(amt) ? 0 : 2,
        }).format(amt);
      }
    });
  </script>
</Base>
