---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/components/PageHeader.astro";

const rules = [
  "Treat every firearm as if it is loaded.",
  "Never point the muzzle at anything you are not willing to destroy.",
  "Keep your finger off the trigger until your sights are on target and you have decided to fire.",
  "Be sure of your target and what is beyond it.",
];

const steelTips = [
  "Only shoot AR500 (or harder) steel rated for your load — never mild or unknown steel.",
  "Respect minimum distances: a common guideline is 10+ yd for handgun and 100+ yd for rifle. Defer to your range's rules.",
  "Hang steel so it can swing or move; this dramatically reduces splatter and extends target life.",
  "Keep the face square (90°) to the line of fire — angled steel directs fragments unpredictably.",
  "Stop shooting any target that becomes pitted, dimpled, or cratered. Damaged steel can deflect fragments back toward the line.",
  "Always wear eye and ear protection, and make sure everyone downrange-adjacent is protected too.",
  "Avoid steel-core, armor-piercing, or extremely high-velocity rounds on reactive steel.",
];
---
<Base title="Range Safety" description="The four rules of firearm safety plus best practices for shooting reactive AR500 steel targets safely.">
  <PageHeader
    title="Range safety"
    lead="Reactive targets are a blast — literally — but only when used responsibly. Read this before you set up steel."
  />

  <section class="container-page max-w-3xl py-12 space-y-12">
    <div>
      <h2 class="font-display text-2xl font-bold text-steel-50">The four rules</h2>
      <ol class="mt-5 space-y-3">
        {rules.map((r, i) => (
          <li class="card flex items-start gap-4 p-4">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-blaze-500 font-display font-bold text-white">{i + 1}</span>
            <span class="text-steel-200">{r}</span>
          </li>
        ))}
      </ol>
    </div>

    <div>
      <h2 class="font-display text-2xl font-bold text-steel-50">Shooting steel safely</h2>
      <p class="mt-3 text-steel-400">
        Reactive steel adds a few extra considerations beyond paper. These are general
        best practices, not a substitute for your range's rules or a manufacturer's
        load rating.
      </p>
      <ul class="mt-5 space-y-3">
        {steelTips.map((t) => (
          <li class="flex gap-3 text-steel-300">
            <svg viewBox="0 0 20 20" class="mt-0.5 h-5 w-5 shrink-0 text-splat-500" fill="currentColor" aria-hidden="true">
              <path d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0z"/>
            </svg>
            <span class="text-sm">{t}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="card border-blaze-700/40 bg-blaze-700/5 p-6">
      <p class="text-sm text-steel-300">
        <strong class="text-blaze-300">Disclaimer:</strong> Shooting sports carry
        inherent risk. The information here is provided for general education only and
        does not replace professional instruction, your range's rules, or the safety
        guidance for your specific firearm and ammunition. You are responsible for
        safe and lawful use of all products purchased from Splatter Impacts.
      </p>
    </div>
  </section>
</Base>
