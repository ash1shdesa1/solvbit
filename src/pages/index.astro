---
import Base from "@/layouts/Base.astro";
import ProductCard from "@/components/ProductCard.astro";
import TargetArt from "@/components/TargetArt.astro";
import { getBestsellers, getProducts } from "@/lib/catalog";
import { CATEGORY_LABELS } from "@/lib/types";

const bestsellers = await getBestsellers(8);
const all = await getProducts();
const countByCat = (c: string) => all.filter((p) => p.category === c).length;

const categories = [
  { key: "splatter", art: "bullseye", blurb: "Bright, peel-and-stick paper targets that flash on every hit." },
  { key: "reactive", art: "steel-gong", blurb: "Hardened AR500 steel that rings, swings, and resets." },
  { key: "bundle", art: "bundle", blurb: "Stock the range bag and save with mixed value packs." },
] as const;

const features = [
  { t: "See every hit", d: "Impacts bloom bright chartreuse so you can call shots from the bench — no spotting scope, no walking downrange.", icon: "eye" },
  { t: "Built to last", d: "Through-hardened AR500 steel and heavy coated paper stock that take a beating and keep performing.", icon: "shield" },
  { t: "Ships fast & flat", d: "Targets ship flat in reinforced mailers. Most orders go out within one business day.", icon: "truck" },
  { t: "Made for shooters", d: "Designed by people who actually spend weekends on the range — for drills that build real skill.", icon: "target" },
];
---
<Base>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-steel-800 bg-grid">
    <div class="absolute -right-24 top-1/2 hidden -translate-y-1/2 opacity-90 lg:block">
      <div class="h-[34rem] w-[34rem]"><TargetArt art="bullseye" /></div>
    </div>
    <div class="container-page relative grid gap-8 py-20 lg:py-28">
      <div class="max-w-2xl">
        <span class="inline-flex items-center gap-2 rounded-full border border-steel-700 bg-steel-900/70 px-3 py-1 text-xs font-medium text-splat-500">
          <span class="h-1.5 w-1.5 rounded-full bg-splat-500"></span>
          Reactive &amp; splatter targets
        </span>
        <h1 class="mt-5 font-display text-5xl font-bold leading-[1.05] text-steel-50 sm:text-6xl">
          Give them something <span class="text-blaze-500">different</span> to shoot.
        </h1>
        <p class="mt-5 max-w-xl text-lg text-steel-300">
          High-visibility splatter paper and hardened reactive steel — instant,
          satisfying feedback on every single shot. Sight in faster, train harder,
          and actually enjoy your range day.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/shop" class="btn btn-primary text-base">Shop targets</a>
          <a href="/shop?c=reactive" class="btn btn-ghost text-base">Browse reactive steel</a>
        </div>
        <p class="mt-6 text-sm text-steel-500">Free shipping on orders over $75 · Secure checkout</p>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="border-b border-steel-800 bg-steel-900/40">
    <div class="container-page grid grid-cols-2 gap-px text-center sm:grid-cols-4">
      {[
        ["Free shipping", "On orders $75+"],
        ["See your hits", "Flash on impact"],
        ["AR500 steel", "Through-hardened"],
        ["Secure checkout", "Powered by Shopify"],
      ].map(([t, d]) => (
        <div class="px-4 py-5">
          <p class="font-display text-sm font-semibold text-steel-100">{t}</p>
          <p class="text-xs text-steel-500">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section class="container-page py-16 lg:py-20">
    <div class="reveal flex items-end justify-between gap-4">
      <div>
        <h2 class="font-display text-3xl font-bold text-steel-50">Shop by type</h2>
        <p class="mt-2 text-steel-400">Two ways to see your hits. Pick your poison.</p>
      </div>
      <a href="/shop" class="hidden shrink-0 text-sm font-medium text-blaze-400 hover:text-blaze-300 sm:inline">All targets →</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      {categories.map((c, i) => (
        <a
          href={`/shop?c=${c.key}`}
          class="reveal card group relative flex flex-col overflow-hidden transition-colors hover:border-blaze-600/70"
          data-delay={`${i * 80}ms`}
        >
          <div class="aspect-[16/10] overflow-hidden bg-steel-950">
            <div class="h-full w-full transition-transform duration-500 group-hover:scale-105">
              <TargetArt art={c.art} />
            </div>
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between">
              <h3 class="font-display text-xl font-semibold text-steel-50">{CATEGORY_LABELS[c.key]}</h3>
              <span class="text-xs text-steel-500">{countByCat(c.key)} products</span>
            </div>
            <p class="mt-2 text-sm text-steel-400">{c.blurb}</p>
            <span class="mt-4 inline-block text-sm font-medium text-blaze-400 group-hover:text-blaze-300">Shop now →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Bestsellers -->
  <section class="border-y border-steel-800 bg-steel-900/30">
    <div class="container-page py-16 lg:py-20">
      <div class="reveal flex items-end justify-between gap-4">
        <div>
          <h2 class="font-display text-3xl font-bold text-steel-50">Range favorites</h2>
          <p class="mt-2 text-steel-400">The targets shooters keep coming back for.</p>
        </div>
        <a href="/shop" class="hidden shrink-0 text-sm font-medium text-blaze-400 hover:text-blaze-300 sm:inline">View all →</a>
      </div>
      <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {bestsellers.map((p) => (
          <div class="reveal"><ProductCard product={p} /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="container-page py-16 lg:py-20">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <div class="reveal">
        <h2 class="font-display text-3xl font-bold text-steel-50">Why shooters choose Splatter Impacts</h2>
        <p class="mt-3 max-w-md text-steel-400">
          We make targets we actually want to shoot — high contrast, honest feedback,
          and tough enough to survive a real range season.
        </p>
        <dl class="mt-8 grid gap-6 sm:grid-cols-2">
          {features.map((f) => (
            <div>
              <dt class="font-display text-lg font-semibold text-steel-100">{f.t}</dt>
              <dd class="mt-1 text-sm text-steel-400">{f.d}</dd>
            </div>
          ))}
        </dl>
      </div>
      <div class="reveal card relative aspect-square overflow-hidden" data-delay="120ms">
        <TargetArt art="steel-gong" />
        <div class="absolute bottom-4 left-4 rounded-lg bg-steel-950/80 px-3 py-2 text-sm text-steel-200 backdrop-blur">
          <span class="font-display font-semibold text-splat-500">Ring Gong AR500</span> — hear every hit.
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter / CTA -->
  <section class="border-t border-steel-800 bg-grid">
    <div class="container-page py-16 lg:py-20">
      <div class="reveal card mx-auto max-w-2xl p-8 text-center sm:p-10">
        <h2 class="font-display text-3xl font-bold text-steel-50">Join the range list</h2>
        <p class="mt-2 text-steel-400">New targets, restocks, and the occasional discount code. No spam, ever.</p>
        <form class="mx-auto mt-6 flex max-w-md flex-col gap-3 sm:flex-row" data-newsletter>
          <label class="sr-only" for="email">Email address</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="you@email.com"
            class="flex-1 rounded-lg border border-steel-600 bg-steel-950 px-4 py-3 text-steel-100 placeholder:text-steel-500 focus:border-blaze-500 focus:outline-none"
          />
          <button type="submit" class="btn btn-primary">Sign up</button>
        </form>
        <p data-newsletter-msg hidden class="mt-3 text-sm text-splat-500"></p>
      </div>
    </div>
  </section>

  <script>
    // lightweight client-only newsletter acknowledgement (no backend in demo)
    document.querySelector("[data-newsletter]")?.addEventListener("submit", (e) => {
      e.preventDefault();
      const msg = document.querySelector<HTMLElement>("[data-newsletter-msg]");
      if (msg) {
        msg.textContent = "You're on the list. Welcome aboard!";
        msg.hidden = false;
      }
      (e.target as HTMLFormElement).reset();
    });
  </script>
</Base>
