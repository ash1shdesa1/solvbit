---
import Logo from "@/components/Logo.astro";
import { BRAND, FOOTER_NAV } from "@/lib/nav";
---
<footer class="border-t border-steel-800 bg-steel-950">
  <div class="container-page py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_repeat(3,1fr)]">
      <div>
        <Logo />
        <p class="mt-4 max-w-xs text-sm text-steel-400">
          High-visibility splatter targets and hardened reactive steel — built to
          give shooters instant feedback on every hit.
        </p>
        <p class="mt-4 text-sm text-steel-500">
          <a href={`mailto:${BRAND.email}`} class="hover:text-blaze-400">{BRAND.email}</a>
        </p>
      </div>
      {FOOTER_NAV.map((col) => (
        <div>
          <h3 class="font-display text-sm font-semibold uppercase tracking-wider text-steel-300">{col.title}</h3>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((l) => (
              <li><a href={l.href} class="text-sm text-steel-400 hover:text-blaze-400">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-steel-800 pt-6 text-sm text-steel-500 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; <span data-year>2026</span> {BRAND.name}. All rights reserved.</p>
      <p class="flex items-center gap-2">
        <span class="inline-block h-2 w-2 rounded-full bg-splat-500"></span>
        Always follow the four rules of firearm safety.
      </p>
    </div>
  </div>
</footer>
