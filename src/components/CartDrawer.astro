---
import { CATALOG_MODE } from "@/lib/catalog";
---
<div class="cart-scrim" data-cart-close aria-hidden="true"></div>

<aside class="cart-drawer" role="dialog" aria-modal="true" aria-label="Shopping cart">
  <div class="flex items-center justify-between border-b border-steel-700 px-5 py-4">
    <h2 class="font-display text-lg font-semibold text-steel-50">Your Cart</h2>
    <button type="button" data-cart-close class="rounded-lg p-1.5 text-steel-400 hover:text-blaze-400" aria-label="Close cart">
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="flex-1 overflow-y-auto px-5">
    <div data-cart-empty class="grid h-full place-items-center py-16 text-center">
      <div>
        <p class="font-display text-steel-200">Your cart is empty</p>
        <p class="mt-1 text-sm text-steel-500">Time to find something to shoot.</p>
        <a href="/shop" data-cart-close class="btn btn-primary mt-5">Browse targets</a>
      </div>
    </div>
    <ul data-cart-items class="m-0 list-none p-0"></ul>
  </div>

  <div data-cart-footer hidden class="border-t border-steel-700 px-5 py-4">
    <div class="flex items-center justify-between text-steel-100">
      <span class="text-steel-400">Subtotal</span>
      <span data-cart-subtotal class="font-display text-lg font-semibold">$0</span>
    </div>
    <p class="mt-1 text-xs text-steel-500">Shipping &amp; taxes calculated at checkout.</p>
    <p data-cart-notice hidden class="mt-3 rounded-lg border border-blaze-700/50 bg-blaze-700/10 px-3 py-2 text-sm text-blaze-300"></p>
    <button type="button" data-cart-checkout class="btn btn-primary mt-3 w-full">
      {CATALOG_MODE === "live" ? "Secure checkout" : "Checkout"}
    </button>
    <button type="button" data-cart-close class="btn btn-ghost mt-2 w-full">Keep shopping</button>
  </div>
</aside>
