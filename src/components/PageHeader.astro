---
interface Props {
  title: string;
  lead?: string;
}
const { title, lead } = Astro.props;
---
<section class="border-b border-steel-800 bg-grid">
  <div class="container-page py-12">
    <h1 class="font-display text-4xl font-bold text-steel-50">{title}</h1>
    {lead && <p class="mt-3 max-w-2xl text-lg text-steel-400">{lead}</p>}
  </div>
</section>
