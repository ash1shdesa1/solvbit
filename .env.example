# Copy to .env for local LIVE-mode testing. Leave unset to run in DEMO mode.
# The Storefront access token is a PUBLIC token by design (safe in client code).

PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com
PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_access_token
PUBLIC_SHOPIFY_API_VERSION=2025-01

# Canonical site URL (used for sitemap/canonical tags)
SITE_URL=https://splatterimpacts.com
